<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dungeon_stone_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_profile_avatar"
            android:layout_width="108dp"
            android:layout_height="108dp"
            android:layout_gravity="center_horizontal"
            android:contentDescription="@string/hero_avatar"
            android:src="@drawable/maleoption1"
            app:strokeColor="@color/amber"
            app:strokeWidth="3dp" />

        <TextView
            android:id="@+id/tv_profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:textColor="@color/parchment"
            android:textSize="18sp"
            android:textStyle="bold"
            android:typeface="monospace" />

        <TextView
            android:id="@+id/tv_profile_class"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_badge"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:textColor="@color/parchment"
            android:typeface="monospace" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/dungeon_stone_mid"
            app:cardCornerRadius="14dp"
            app:strokeColor="@color/amber"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView android:id="@+id/tv_profile_level" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/parchment" android:typeface="monospace" />
                <TextView android:id="@+id/tv_profile_xp_next" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/parchment" android:typeface="monospace" />
                <TextView android:id="@+id/tv_profile_tasks" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/parchment" android:typeface="monospace" />
                <TextView android:id="@+id/tv_profile_wins" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/parchment" android:typeface="monospace" />
                <TextView android:id="@+id/tv_profile_streak" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/parchment" android:typeface="monospace" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_profile_weapon"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_avatar_unselected"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/sword" />

            <ImageView
                android:id="@+id/iv_profile_shield"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_avatar_unselected"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/shield" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView android:id="@+id/badge_one" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="6dp" android:src="@android:drawable/btn_star_big_on" />
            <ImageView android:id="@+id/badge_two" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="6dp" android:src="@android:drawable/btn_star_big_on" />
            <ImageView android:id="@+id/badge_three" android:layout_width="36dp" android:layout_height="36dp" android:layout_margin="6dp" android:src="@android:drawable/btn_star_big_on" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_open_shop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:backgroundTint="@color/amber"
            android:text="@string/open_armory"
            android:textColor="@color/dungeon_stone_dark"
            android:textStyle="bold"
            android:typeface="monospace" />
    </LinearLayout>
</ScrollView>


