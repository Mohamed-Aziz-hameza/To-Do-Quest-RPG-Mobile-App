<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    android:backgroundTint="@color/dungeon_stone_mid"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/amber"
    app:strokeWidth="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <View
            android:id="@+id/view_priority_stripe"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_gem_easy" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/layout_raid_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_raid_boss"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@string/raid_boss"
                    android:src="@drawable/fireraidboss" />

                <TextView
                    android:id="@+id/tv_raid_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/raid_boss"
                    android:textColor="@color/amber"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_task_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/parchment"
                android:textStyle="bold"
                android:typeface="monospace" />

            <TextView
                android:id="@+id/tv_task_priority"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/amber"
                android:textSize="12sp"
                android:typeface="monospace" />

            <TextView
                android:id="@+id/tv_task_xp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/parchment"
                android:textSize="12sp"
                android:typeface="monospace" />

            <TextView
                android:id="@+id/tv_raid_hp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/amber"
                android:textSize="11sp"
                android:typeface="monospace"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_raid_room"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:textColor="@color/parchment"
                android:textSize="11sp"
                android:typeface="monospace"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_raid_assigned"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:textColor="@color/parchment"
                android:textSize="11sp"
                android:typeface="monospace"
                android:visibility="gone" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/cb_task_complete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/amber" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
