<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dungeon_stone_dark"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dungeon_realm"
        android:textColor="@color/parchment"
        android:textSize="22sp"
        android:textStyle="bold"
        android:typeface="monospace" />

    <TextView
        android:id="@+id/tv_key_counter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/amber"
        android:textSize="18sp"
        android:textStyle="bold"
        android:typeface="monospace" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/dungeon_stone_mid"
        app:cardCornerRadius="14dp"
        app:strokeColor="@color/amber"
        app:strokeWidth="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:contentDescription="@string/goblin_dungeon"
                android:scaleType="centerCrop"
                android:src="@drawable/dungeonicon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/goblin_dungeon"
                android:textColor="@color/parchment"
                android:textStyle="bold"
                android:typeface="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/goblin_subtitle"
                android:textColor="@color/parchment"
                android:typeface="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/goblin_difficulty"
                android:textColor="@color/amber"
                android:typeface="monospace" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_enter_dungeon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/amber"
                android:text="@string/enter_dungeon"
                android:textColor="@color/dungeon_stone_dark"
                android:textStyle="bold"
                android:typeface="monospace" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>

